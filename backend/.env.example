# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── AI Models ─────────────────────────────────────────────────────────────────
# Prompt generation / architectural thinking (Gemini 3.1 Flash Preview)
GEMINI_MODEL=google/gemini-3.1-flash

# Image generation (Nano Banana Pro — Gemini 3 Pro Image, highest quality)
NANO_BANANA_MODEL=google/gemini-3-pro-image-preview

# ── App ───────────────────────────────────────────────────────────────────────
DATA_DIR=data/projects
MAX_CONCURRENT_GENERATIONS=3

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:4200
